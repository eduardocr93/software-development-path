# Example environment variables for Flask Project
# Rename this file to .env and set your own values.

FLASK_ENV=development
SQLALCHEMY_DATABASE_URI=postgresql+psycopg2://<db_user>:<db_password>@<db_host>:<db_port>/<db_name>
JWT_SECRET_KEY=change-me-to-a-secure-random-value
JWT_ACCESS_TOKEN_EXPIRES=3600
REDIS_HOST=<redis_host>
REDIS_PORT=6379
REDIS_USERNAME=<redis_username>
REDIS_PASSWORD=<redis_password>
REDIS_DB=0
